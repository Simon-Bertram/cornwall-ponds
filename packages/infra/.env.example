# Alchemy / Cloudflare (packages/infra loads apps/server and apps/web .env too)
ALCHEMY_PASSWORD=change-me
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Web — URLs in apps/web/.env.development (local) and apps/web/.env.production (deploy)
# Server secrets in apps/server/.env; URLs in .env.development / .env.production
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Auth <auth@yourdomain.com>

# Remote D1 push only (packages/db/drizzle.config.ts)
CLOUDFLARE_DATABASE_ID=
