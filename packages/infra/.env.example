# Alchemy / Cloudflare (this file only — packages/infra/.env)
# Required to decrypt secrets in .alchemy state. Must match the password used when secrets were first encrypted.
# If devcontainer sets an empty ALCHEMY_PASSWORD from the host, packages/infra/.env still wins (override: true in alchemy.run.ts).
ALCHEMY_PASSWORD=change-me
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Google OAuth + Resend + BETTER_AUTH_SECRET → apps/server/.env
# Local/prod URLs → apps/server/.env.development and apps/server/.env.production
# PUBLIC_SERVER_URL → apps/web/.env.development and apps/web/.env.production
# See apps/server/.env.example for Google redirect URIs and Resend setup.

# Remote D1 push only (packages/db/drizzle.config.ts)
CLOUDFLARE_DATABASE_ID=
