---
import AuthPageLayout from "../components/auth/AuthPageLayout.astro";
import { SignInForm } from "../components/auth/SignInForm.tsx";
---

<AuthPageLayout title="Sign In - cornwall-ponds">
  <div
    class="mx-auto flex w-full max-w-5xl flex-col overflow-hidden rounded-xl bg-card px-4 shadow-sm ring-1 ring-foreground/5 sm:px-6 lg:min-h-[min(40rem,calc(100vh-10rem))] lg:flex-row"
  >
    <div class="relative hidden min-h-52 lg:block lg:w-[45%] xl:w-1/2">
      <img
        src="/images/portfolio-3.jpg"
        alt="Natural swimming pond project by Cornwall Ponds"
        class="absolute inset-0 h-full w-full object-cover"
        width="1600"
        height="1067"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div
      class="flex min-w-0 w-full flex-1 flex-col bg-muted lg:w-[55%] xl:w-1/2"
    >
      <SignInForm splitLayout={true} />
    </div>
  </div>
</AuthPageLayout>
