---
import Layout from "../layouts/Layout.astro";
import { projects, toTransformationProjects } from "../lib/projects.ts";
import HeroSlider from "../components/hero/HeroSlider.astro";
import ServicesPreview from "../components/ServicesPreview.astro";
import BeforeAfter from "../components/before-and-after/BeforeAfter.tsx";
import HowWeWork from "../components/HowWeWork.astro";
import { TestimonialsSection } from "../components/testimonials-section.tsx";
import GetStarted from "../components/GetStarted.astro";

const transformationProjects = toTransformationProjects(projects);
---

<Layout title="cornwall-ponds">
  <main id="main-content" tabindex="-1">
    <HeroSlider />
    <ServicesPreview />
    <!-- Why: this React component requires client-side handlers for slider/nav interactions -->
    <BeforeAfter client:visible projects={transformationProjects} />
    <HowWeWork />
    <TestimonialsSection />
    <GetStarted />
  </main>
</Layout>
