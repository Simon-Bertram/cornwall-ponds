---
import Layout from "../layouts/Layout.astro";
import { projects } from "../lib/projects.ts";
import HeroSlider from "../components/hero/HeroSlider.astro";
import ServicesPreview from "../components/ServicesPreview.astro";
import BeforeAfter from "../components/before-and-after/BeforeAfter.tsx";
import HowWeWork from "../components/HowWeWork.astro";
import { TestimonialsSection } from "../components/testimonials-section.tsx";
import GetStarted from "../components/GetStarted.astro";
---

<Layout title="cornwall-ponds">
  <main id="main-content" tabindex="-1">
    <HeroSlider />
    <ServicesPreview />
    <!-- Why: this React component requires client-side handlers for slider/nav interactions -->
    <BeforeAfter client:visible projects={projects} />
    <HowWeWork />
    <TestimonialsSection />
    <GetStarted />
  </main>
</Layout>

<script>
  import { PUBLIC_SERVER_URL } from "astro:env/client";

  const statusDot = document.getElementById("status-dot")!;
  const statusText = document.getElementById("status-text")!;

  async function checkHealth() {
    try {
      const res = await fetch(`${PUBLIC_SERVER_URL}/health`, {
        credentials: "include",
      });
      if (!res.ok) throw new Error("bad status");
      statusDot.className = "h-2 w-2 rounded-full bg-green-500";
      statusText.textContent = "Connected";
    } catch {
      statusDot.className = "h-2 w-2 rounded-full bg-red-500";
      statusText.textContent = "Disconnected";
    }
  }

  function runWhenIdle(fn: () => void) {
    const ric = (
      window as Window & { requestIdleCallback?: (cb: () => void) => number }
    ).requestIdleCallback;
    if (typeof ric === "function") {
      ric(fn);
    } else {
      setTimeout(fn, 1);
    }
  }

  runWhenIdle(() => {
    void checkHealth();
  });
</script>
