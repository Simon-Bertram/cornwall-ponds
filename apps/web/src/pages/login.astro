---
import Layout from "@/layouts/Layout.astro";
import { MagicLinkAuthForm } from "@/components/auth/MagicLinkAuthForm.tsx";
---

<Layout>
  <div
    class="relative z-0 flex min-h-svh flex-col items-center justify-center p-6 md:p-10"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 bg-[url('/images/swimming-pond.jpg')] bg-cover bg-center bg-no-repeat"
    >
    </div>
    <div class="relative z-10 w-full max-w-sm md:max-w-lg">
      <!-- Why: client-only avoids workerd SSR duplicate-React; form needs browser APIs -->
      <MagicLinkAuthForm client:only="react" />
    </div>
  </div>
</Layout>
