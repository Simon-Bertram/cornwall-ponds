---
import Layout from "@/layouts/Layout.astro";
import "../styles/global.css";
import { LoginForm } from "@/components/login-form.tsx";
---

<Layout>
  <div
    class="relative z-0 flex min-h-svh flex-col items-center justify-center p-6 md:p-10"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 bg-[url('/images/swimming-pond.jpg')] bg-cover bg-center bg-no-repeat"
    >
    </div>
    <div class="relative z-10 w-full max-w-sm md:max-w-lg">
      <LoginForm client:load />
      <!-- Why: email submit and magic-link API need client-side auth client -->
    </div>
  </div>
</Layout>
