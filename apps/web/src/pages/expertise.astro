---
import PageLayout from "../layouts/PageLayout.astro";
import CredentialsSection from "../components/services/CredentialsSection.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";
import GetStarted from "../components/GetStarted.astro";
import {
	getCredentials,
	getExpertisePageContent,
	getTestimonials,
} from "../lib/content";

const expertisePageContent = await getExpertisePageContent();
const credentials = await getCredentials();
const testimonials = await getTestimonials();

const { header, whyChooseUs, credentialsSection, testimonialsTitle } =
  expertisePageContent;
---

<PageLayout
  title={expertisePageContent.seo.title}
  description={expertisePageContent.seo.description}
>
  <section>
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <!-- Page Header -->
      <div class="mx-auto max-w-2xl text-center py-12 mb-16">
        <h1
          class="font-serif text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl mb-6"
        >
          {header.title}
        </h1>
        <p class="text-lg text-foreground/80">
          {header.intro}
        </p>
      </div>
    </div>
  </section>

  <!-- Trust Pillars & Stats (WhyChooseUs component) -->
  <WhyChooseUs
    eyebrow={whyChooseUs.eyebrow}
    title={whyChooseUs.title}
    description={whyChooseUs.description}
    pillars={whyChooseUs.pillars}
    stats={whyChooseUs.stats}
  />

  <!-- Credentials section -->
  <CredentialsSection credentials={credentials} heading={credentialsSection} />

  <!-- Testimonials -->
  <section class="py-24 bg-muted">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-foreground">
          {testimonialsTitle}
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          testimonials.slice(0, 3).map((t) => (
            <div class="bg-card p-8 rounded-3xl border border-foreground/5 shadow-sm flex flex-col">
              <div class="flex gap-1 text-primary mb-5">
                {[...Array(5)].map(() => (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 fill-current"
                    viewBox="0 0 20 20"
                    aria-hidden="true"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-foreground/80 text-sm leading-relaxed italic mb-6 flex-1">
                "{t.quote}"
              </p>
              <div>
                <p class="font-bold text-sm text-foreground">{t.name}</p>
                <p class="text-xs text-foreground/60">{t.location}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <GetStarted />
</PageLayout>
