---
// apps/web/src/pages/services.astro
// Moved from services/index.astro to fix Astro 6 beta CSS asset resolution bug
// with sub-directory index pages.

import PageLayout from "../layouts/PageLayout.astro";
import GetStarted from "../components/GetStarted.astro";
import CredentialsSection from "../components/services/CredentialsSection.astro";
import InvestmentGuideSection from "../components/services/InvestmentGuideSection.astro";
import ServicesHeroGrid from "../components/services/ServicesHeroGrid.astro";
import ServicesPhilosophyStrip from "../components/services/ServicesPhilosophyStrip.astro";
import ServicesDetailBlocks from "../components/services/ServicesDetailBlocks.astro";
import TestimonialsPreviewSection from "../components/services/TestimonialsPreviewSection.astro";
import { credentials } from "../lib/credentials";
import { guidePrices } from "../lib/pricing";
import { servicesPageContent } from "../lib/pages/services";
import { services, projects, testimonials } from "../lib/projects";

// Resolve each pricing row's display name from the service entity.
const guidePriceRows = guidePrices.map((row) => {
  const service = services.find((s) => s.slug === row.serviceSlug);
  return { service: service?.title ?? row.serviceSlug, price: row.price };
});
---

<PageLayout
  title={servicesPageContent.seo.title}
  description={servicesPageContent.seo.description}
>
  <ServicesHeroGrid services={services} heading={servicesPageContent.hero} />
  <ServicesPhilosophyStrip pillars={servicesPageContent.philosophyPillars} />
  <ServicesDetailBlocks services={services} projects={projects} />
  <InvestmentGuideSection
    guidePrices={guidePriceRows}
    heading={servicesPageContent.investmentGuide}
  />
  <CredentialsSection
    credentials={credentials}
    heading={servicesPageContent.credentialsSection}
  />
  <TestimonialsPreviewSection
    testimonials={testimonials}
    title={servicesPageContent.testimonialsTitle}
  />

  <!-- ── Section 7: Final CTA ── -->
  <GetStarted />
</PageLayout>
