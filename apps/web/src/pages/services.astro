---
// apps/web/src/pages/services.astro
// Moved from services/index.astro to fix Astro 6 beta CSS asset resolution bug
// with sub-directory index pages.

import PageLayout from "../layouts/PageLayout.astro";
import GetStarted from "../components/GetStarted.astro";
import CredentialsSection from "../components/services/CredentialsSection.astro";
import InvestmentGuideSection from "../components/services/InvestmentGuideSection.astro";
