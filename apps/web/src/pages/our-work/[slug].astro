---
import CtaLink from "../../components/ui/CtaLink.astro";
import PageLayout from "../../layouts/PageLayout.astro";
import { projects } from "../../lib/projects";
import ProjectStat from "../../components/ProjectStat.astro";

// SSR mode: getStaticPaths() is ignored. Look up the project from the URL param at request time.
const { slug } = Astro.params;
const project = projects.find((p) => p.slug === slug);

if (!project) {
  return Astro.redirect("/our-work", 404);
}
---

<PageLayout
  title={`${project.title} | Cornwall Ponds`}
  description={project.shortDescription}
>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    {/* Header */}
    <div class="my-12">
      <a
        href="/our-work"
        class="text-sm text-primary hover:text-primary-focus font-medium inline-flex items-center gap-1 mb-8"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Portfolio
      </a>

      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <div class="flex flex-wrap gap-2 mb-4">
            <span
              class="badge badge-primary font-semibold text-xs py-2 px-2 shadow-sm"
            >
              {project.serviceType}
            </span>
            <span
              class="badge badge-neutral bg-foreground/80 px-2 py-2 text-background border-none font-medium text-xs shadow-sm capitalize"
            >
              {project.location}
            </span>
          </div>
          <h1
            class="font-serif text-3xl font-bold tracking-tight text-foreground sm:text-5xl"
          >
            {project.title}
          </h1>
        </div>

        <dl
          class="flex flex-wrap gap-4 text-sm text-foreground/80 text-left md:text-right"
          aria-label="Project statistics"
        >
          {
            project.stats.duration && (
              <ProjectStat type="duration" value={project.stats.duration} />
            )
          }
          {
            project.stats.volume && (
              <ProjectStat type="volume" value={project.stats.volume} />
            )
          }
          {
            project.stats.area && (
              <ProjectStat type="area" value={project.stats.area} />
            )
          }
          {
            project.stats.depth && (
              <ProjectStat type="depth" value={project.stats.depth} />
            )
          }
        </dl>
      </div>
    </div>

    {/* Main Content Grid */}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-32">
      <div class="lg:col-span-2 space-y-8">
        {/* Main Image Banner */}
        <div
          class="aspect-video w-full rounded-2xl overflow-hidden mb-12 shadow-md"
        >
          <img
            src={project.afterImage.src}
            alt={project.afterImage.alt}
            class="w-full h-full object-cover"
          />
        </div>

        <div>
          <h2 class="font-serif text-2xl font-bold mb-4">The Challenge</h2>
          <p class="text-foreground/80 text-lg leading-relaxed">
            {project.challenge}
          </p>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-bold mb-4">Our Solution</h2>
          <p class="text-foreground/80 text-lg leading-relaxed">
            {project.solution}
          </p>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-bold mb-4">The Result</h2>
          <p class="text-foreground/80 text-lg leading-relaxed">
            {project.result}
          </p>
        </div>
      </div>

      {/* Sidebar Gallery */}
      <div class="space-y-6">
        <h3 class="font-serif text-xl font-bold mb-4">Project Gallery</h3>
        {
          project.gallery.map((img) => (
            <div class="aspect-4/3 rounded-xl overflow-hidden shadow-sm">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              />
            </div>
          ))
        }

        {/* Call to action inside sidebar */}
        <div
          class="mt-12 bg-primary/10 rounded-2xl p-6 border border-primary/20 text-center"
        >
          <h4 class="font-serif text-lg font-bold mb-2">
            Inspired by this project?
          </h4>
          <p class="text-sm text-foreground/80 mb-6">
            Contact us to discuss how we can transform your garden.
          </p>
          <CtaLink href="/contact" className="w-full">
            Request a Consultation
          </CtaLink>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
