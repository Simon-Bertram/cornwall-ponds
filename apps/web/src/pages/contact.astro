---
import PageLayout from "../layouts/PageLayout.astro";
import ContactPageHero from "../components/contact/ContactPageHero.astro";
import ContactDetailsCard from "../components/contact/ContactDetailsCard.astro";
import { ContactQuoteForm } from "../components/contact/ContactQuoteForm";
---

<PageLayout
  title="Request a Quote | Cornwall Ponds"
  description="Contact our expert team to discuss your bespoke pond design, natural swimming pool, or water feature project in Cornwall and Devon."
>
  <div
    class="mx-auto mb-18 flex max-w-7xl flex-col gap-16 px-4 md:px-6 lg:px-8"
  >
    <ContactPageHero />

    <div class="contact-layout">
      <div class="contact-layout__details">
        <ContactDetailsCard />
      </div>
      <div class="contact-layout__form">
        <ContactQuoteForm client:load />
        <!-- Why: Turnstile widget and cross-origin API submit need the client -->
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .contact-layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .contact-layout__details,
  .contact-layout__form {
    width: 100%;
  }

  @media (min-width: 1024px) {
    .contact-layout {
      flex-direction: row;
      align-items: flex-start;
      gap: 2rem;
    }

    .contact-layout__details {
      flex: 0 0 450px;
      width: 450px;
      max-width: 450px;
    }

    .contact-layout__form {
      flex: 1 1 0%;
      min-width: 0;
    }
  }

  @media (min-width: 1280px) {
    .contact-layout {
      gap: 4rem;
    }
  }
</style>
