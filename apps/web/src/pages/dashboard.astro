---
import { DashboardView } from "@/components/auth/DashboardView";
import Layout from "../layouts/Layout.astro";

const user = Astro.locals.user;
const initialDisplayName = user
	? user.name || user.email?.split("@")[0] || "User"
	: undefined;
const initialEmail = user?.email;
---

<Layout title="Dashboard - cornwall-ponds">
  <main class="mx-auto max-w-4xl px-4 py-12 sm:py-18">
    <!-- Why: client:load — session cookie is on API host; auth via getSession -->
    <DashboardView
      client:load
      initialDisplayName={initialDisplayName}
      initialEmail={initialEmail}
    />
  </main>
</Layout>
