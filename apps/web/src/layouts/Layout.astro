---
import { Font } from "astro:assets";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "cornwall-ponds", description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- theme-change Astro pattern: https://github.com/saadeghi/theme-change#readme (Astro section) — npm only, no CDN -->
    <script is:inline>
      // Prevents flash of wrong theme before paint (FART). localStorage "theme" is written by theme-change.
      if (localStorage.getItem("theme") === null) {
        document.documentElement.setAttribute("data-theme", "light");
      } else {
        document.documentElement.setAttribute(
          "data-theme",
          localStorage.getItem("theme"),
        );
      }
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Font cssVariable="--font-manrope" preload />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body id="top" class="min-h-screen bg-background text-foreground">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
