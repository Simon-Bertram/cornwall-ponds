---
import { Font } from "astro:assets";
import "../styles/global.css";
import Header from "../components/header/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "cornwall-ponds", description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Prevents flash of wrong theme before paint. `theme` is read/written by ThemeController + this script.
      (function () {
        var t = localStorage.getItem("theme");
        if (t === "light") {
          localStorage.setItem("theme", "aquascape-pro");
          t = "aquascape-pro";
        } else if (t === "dark") {
          localStorage.setItem("theme", "aquascape-midnight");
          t = "aquascape-midnight";
        }
        if (t === null) {
          document.documentElement.setAttribute("data-theme", "aquascape-pro");
        } else {
          document.documentElement.setAttribute("data-theme", t);
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Font cssVariable="--font-manrope" preload />
    <Font cssVariable="--font-work-sans" preload />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body id="top" class="min-h-screen bg-background text-foreground">
    <Header />
    <slot />
    <Footer />
    <script is:inline>
      (function () {
        const debugEndpoint =
          "http://localhost:7491/ingest/e8332152-a9b9-4809-aab8-43213961e9a7";
        const sessionId = "c3175d";
        const runId = `${window.location.pathname}-${Date.now()}`;

        function getFontResources() {
          return performance
            .getEntriesByType("resource")
            .filter((entry) => {
              return (
                entry.initiatorType === "font" ||
                entry.name.includes("fonts.gstatic") ||
                entry.name.endsWith(".woff2")
              );
            })
            .map((entry) => ({
              name: entry.name.split("/").slice(-1)[0],
              initiatorType: entry.initiatorType,
              duration: Math.round(entry.duration),
              transferSize:
                typeof entry.transferSize === "number" ? entry.transferSize : null,
            }));
        }

        function getFontState() {
          const rootStyles = getComputedStyle(document.documentElement);
          const body = document.body;
          const heading = document.querySelector("h1, h2, h3, h4, h5, h6");

          return {
            path: window.location.pathname,
            readyState: document.readyState,
            fontStatus: document.fonts ? document.fonts.status : "unsupported",
            workSansLoaded: document.fonts
              ? document.fonts.check('16px "Work Sans"')
              : null,
            manropeLoaded: document.fonts
              ? document.fonts.check('16px "Manrope"')
              : null,
            bodyFontFamily: body ? getComputedStyle(body).fontFamily : null,
            headingFontFamily: heading ? getComputedStyle(heading).fontFamily : null,
            fontSansVar: rootStyles.getPropertyValue("--font-sans").trim(),
            fontDisplayVar: rootStyles.getPropertyValue("--font-display").trim(),
            fontResources: getFontResources(),
            navigationType:
              performance.getEntriesByType("navigation")[0]?.type ?? "unknown",
          };
        }

        function postDebug(hypothesisId, location, message, data) {
          fetch(debugEndpoint, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-Debug-Session-Id": sessionId,
            },
            body: JSON.stringify({
              sessionId,
              runId,
              hypothesisId,
              location,
              message,
              data,
              timestamp: Date.now(),
            }),
          }).catch(() => {});
        }

        function logInitialState() {
          // #region agent log
          postDebug(
            "H1",
            "src/layouts/Layout.astro:90",
            "font-state-initial",
            getFontState(),
          );
          // #endregion
        }

        function logAstroPageLoad() {
          // #region agent log
          postDebug(
            "H2",
            "src/layouts/Layout.astro:101",
            "font-state-astro-page-load",
            getFontState(),
          );
          // #endregion
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", logInitialState, {
            once: true,
          });
        } else {
          logInitialState();
        }

        document.addEventListener("astro:page-load", logAstroPageLoad);

        if (document.fonts) {
          document.fonts.addEventListener("loadingdone", function (event) {
            // #region agent log
            postDebug(
              "H3",
              "src/layouts/Layout.astro:123",
              "font-state-loadingdone",
              {
                ...getFontState(),
                loadedFonts: Array.from(event.fontfaces || []).map((fontFace) => ({
                  family: fontFace.family,
                  status: fontFace.status,
                  weight: fontFace.weight,
                })),
              },
            );
            // #endregion
          });

          document.fonts.ready.then(function () {
            // #region agent log
            postDebug(
              "H4",
              "src/layouts/Layout.astro:140",
              "font-state-ready",
              getFontState(),
            );
            // #endregion
          });
        }
      })();
    </script>
  </body>
</html>
