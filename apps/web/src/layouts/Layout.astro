---
import { Font } from "astro:assets";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "cornwall-ponds", description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Prevents flash of wrong theme before paint. `theme` is read/written by ThemeController + this script.
      (function () {
        var t = localStorage.getItem("theme");
        if (t === "light") {
          localStorage.setItem("theme", "aquascape-pro");
          t = "aquascape-pro";
        } else if (t === "dark") {
          localStorage.setItem("theme", "aquascape-midnight");
          t = "aquascape-midnight";
        }
        if (t === null) {
          document.documentElement.setAttribute("data-theme", "aquascape-pro");
        } else {
          document.documentElement.setAttribute("data-theme", t);
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Font cssVariable="--font-manrope" preload />
    <Font cssVariable="--font-work-sans" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body id="top" class="min-h-screen bg-background text-foreground">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
