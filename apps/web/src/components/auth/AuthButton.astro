---
import CtaLink from "../ui/CtaLink.astro";

const user = Astro.locals.user;
const isLoggedIn = Boolean(user);
const displayName =
	user?.name || user?.email?.split("@")[0] || "User";
---

<div
  class="flex items-center gap-2"
  id="user-menu-container"
  data-is-logged-in={isLoggedIn ? "true" : "false"}
>
  <CtaLink
    href="/login"
    id="login-link"
    className={`antialiased rounded-xl text-sm${isLoggedIn ? " hidden" : ""}`}
  >
    Sign In
  </CtaLink>
  <div
    id="user-menu"
    class={isLoggedIn ? "flex items-center gap-3" : "hidden items-center gap-3"}
  >
    <span class="text-sm hidden sm:inline" id="user-display">{displayName}</span>
    <button
      id="signout-button"
      class="antialiased rounded-xl btn btn-error text-sm"
    >
      Sign Out
    </button>
  </div>
</div>

<script>
  import { authClient } from "../../lib/auth-client";

  const container = document.getElementById("user-menu-container");
  const isLoggedIn = container?.dataset.isLoggedIn === "true";
  const loginLink = document.getElementById("login-link");
  const userMenu = document.getElementById("user-menu");
  const userDisplay = document.getElementById("user-display");
  const signOutButton = document.getElementById("signout-button");

  async function syncSession() {
    if (isLoggedIn) return;

    try {
      const { data: session } = await authClient.getSession();
      if (session?.user) {
        loginLink?.classList.add("hidden");
        userMenu?.classList.remove("hidden");
        userMenu?.classList.add("flex");
        if (userDisplay) {
          userDisplay.textContent =
            session.user.name || session.user.email?.split("@")[0] || "User";
        }
      }
    } catch {
      // Not logged in
    }
  }

  signOutButton?.addEventListener("click", async () => {
    await authClient.signOut({
      fetchOptions: {
        onSuccess: () => {
          window.location.href = "/";
        },
      },
    });
  });

  syncSession();
</script>
