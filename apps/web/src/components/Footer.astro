---
// Footer.astro — Step F: Site-wide footer
// Pure Astro (static)
// Data: Sourced from ../lib/projects.ts and ../lib/site-settings.ts
// Colours: bg-footer / text-footer-foreground / text-footer-muted (theme tokens)

import { services, locations } from "../lib/projects";
import { siteSettings } from "../lib/site-settings";
import BackToTopButton from "./BackToTopButton.astro";

const currentYear = new Date().getFullYear();

const brandIcon = {
  viewBox: "0 0 24 24",
  paths: [
    {
      d: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z",
    },
    { d: "M8 12c0-2.21 1.79-4 4-4s4 1.79 4 4-1.79 4-4 4" },
    { d: "M6 16c1.5 1.5 3.5 2 6 2" },
  ],
} as const;

const phoneIcon = {
  viewBox: "0 0 24 24",
  paths: [
    {
      strokeLinecap: "round",
      strokeLinejoin: "round",
      d: "M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z",
    },
  ],
} as const;

const emailIcon = {
  viewBox: "0 0 24 24",
  paths: [
    {
      strokeLinecap: "round",
      strokeLinejoin: "round",
      d: "M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75",
    },
  ],
} as const;

const locationIcon = {
  viewBox: "0 0 24 24",
  paths: [
    {
      strokeLinecap: "round",
      strokeLinejoin: "round",
      d: "M15 10.5a3 3 0 11-6 0 3 3 0 016 0z",
    },
    {
      strokeLinecap: "round",
      strokeLinejoin: "round",
      d: "M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1115 0z",
    },
  ],
} as const;

const companyLinks = siteSettings.footerQuickLinks;
---

<footer class="bg-footer text-footer-foreground" role="contentinfo">
  <div class="mx-auto max-w-7xl px-6 py-14 lg:py-18">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
      {/* ── Brand Column ── */}
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="flex h-10 w-10 items-center justify-center rounded-full bg-primary shadow-sm"
          >
            <svg
              viewBox={brandIcon.viewBox}
              class="h-5 w-5 text-primary-foreground"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              {brandIcon.paths.map((path) => <path {...path} />)}
            </svg>
          </div>
          <div class="flex flex-col">
            <a
              href="/"
              class="hover:text-secondary transition-colors duration-200"
            >
              <span
                class="font-serif text-lg font-bold tracking-tight leading-none"
                >{siteSettings.siteName}</span
              >
              <span
                class="text-[11px] tracking-widest uppercase text-footer-muted"
                >{siteSettings.tagline}</span
              >
            </a>
          </div>
        </div>
        <p class="text-sm leading-relaxed text-footer-muted mb-8 max-w-sm">
          {siteSettings.footerBlurb}
        </p>
        <address class="flex flex-col gap-4">
          <a
            href={siteSettings.phone.href}
            class="flex items-center gap-3 text-sm text-footer-muted hover:text-footer-foreground transition-colors duration-200"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-footer-muted"
              fill="none"
              viewBox={phoneIcon.viewBox}
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              {phoneIcon.paths.map((path) => <path {...path} />)}
            </svg>
            {siteSettings.phone.display}
          </a>
          <a
            href={`mailto:${siteSettings.email}`}
            class="flex items-center gap-3 text-sm text-footer-muted hover:text-footer-foreground transition-colors duration-200"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-footer-muted"
              fill="none"
              viewBox={emailIcon.viewBox}
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              {emailIcon.paths.map((path) => <path {...path} />)}
            </svg>
            {siteSettings.email}
          </a>
          <span class="flex items-center gap-3 text-sm text-footer-muted">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-footer-muted"
              fill="none"
              viewBox={locationIcon.viewBox}
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              {locationIcon.paths.map((path) => <path {...path} />)}
            </svg>
            {siteSettings.serviceArea}
          </span>
        </address>
      </div>

      {/* ── Services Column ── */}
      <div>
        <h3
          class="font-serif text-base font-bold mb-6 text-footer-foreground tracking-wide"
        >
          Our Services
        </h3>
        <ul class="flex flex-col gap-3">
          {
            services.map((service) => (
              <li>
                <a
                  href={`/services#${service.slug}`}
                  class="text-sm text-footer-muted hover:text-footer-foreground hover:underline transition-colors duration-200"
                >
                  {service.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* ── Company Column ── */}
      <div>
        <h3
          class="font-serif text-base font-bold mb-6 text-footer-foreground tracking-wide"
        >
          Quick Links
        </h3>
        <ul class="flex flex-col gap-3">
          {
            companyLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-footer-muted hover:text-footer-foreground hover:underline transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* ── Areas Column ── */}
      <div>
        <h3
          class="font-serif text-base font-bold mb-6 text-footer-foreground tracking-wide"
        >
          Areas We Cover
        </h3>
        <ul class="flex flex-col gap-3">
          {
            locations.map((loc) => (
              <li>
                <a
                  href={`/our-work?location=${loc}`}
                  class="text-sm text-footer-muted hover:text-footer-foreground hover:underline transition-colors duration-200"
                >
                  {loc}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    {/* ── Back to Top Button ── */}
    <div class="flex justify-end">
      <BackToTopButton />
    </div>

    {/* ── Bottom Bar ── */}
    <div
      class="mt-6 pt-8 border-t border-footer-foreground/15 flex flex-col gap-6 md:flex-row md:items-center md:justify-between"
    >
      <p class="text-xs text-footer-muted font-medium">
        &copy; {currentYear} {siteSettings.copyrightNotice}
      </p>
      <div class="flex flex-wrap items-center gap-6 md:justify-end">
        {
          siteSettings.legalLinks.map((link) => (
            <a
              href={link.href}
              class="text-xs text-footer-muted hover:text-footer-foreground transition-colors duration-200"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
