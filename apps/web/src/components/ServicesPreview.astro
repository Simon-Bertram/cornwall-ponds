---
// ServicesPreview.astro — Step B: "Our Services" section
// Pure Astro (static); copy and services passed in from the page
// Designed per graphic-designer.md: 4/8px grid, visual hierarchy, WCAG AA contrast
import CtaLink from './ui/CtaLink.astro'
import SectionFooterCta from './SectionFooterCta.astro'
import SectionHeader from './SectionHeader.astro'
import type { HomePageContent } from '../lib/pages/home'
import type { Service } from '../lib/projects'

interface Props {
	content: HomePageContent['servicesPreview']
	services: Service[]
}

const { content, services } = Astro.props
---

<section
  aria-labelledby="services-heading"
  class="py-24 sm:py-32 bg-background"
>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <!-- Section header -->
    <SectionHeader
      eyebrow={content.eyebrow}
      title={content.title}
      description={content.description}
      headingId="services-heading"
      className="mb-16"
    />

    <!-- Services grid -->
    <ul
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8"
      role="list"
    >
      {services.map((service) => (
        <li class="group">
          <article
            class="flex flex-col h-full bg-card rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-border hover:border-primary/20"
            aria-label={service.title}
          >
            <!-- Visual header block -->
            <div
              class="relative h-64 bg-linear-to-br from-primary/40 to-accent/30 flex items-center justify-center overflow-hidden"
              aria-hidden="true"
            >
              {service.image && <img src={service.image.src} alt={service.image.alt} class="absolute inset-0 w-full h-full object-cover" />}              
            </div>

            <!-- Card body -->
            <div class="flex flex-col flex-1 p-6 gap-4">

              <!-- Title + description -->
              <div>
                <h3 class="font-serif text-xl font-bold text-foreground mb-2 group-hover:text-primary transition-colors duration-300">
                  {service.title}
                </h3>
                <p class="text-foreground/70 text-sm leading-relaxed">
                  {service.shortDescription}
                </p>
              </div>

              <!-- Feature list (first 3) -->
              <ul class="flex flex-col gap-2 flex-1" role="list" aria-label={`${service.title} features`}>
                {service.features.slice(0, 3).map((feature) => (
                  <li class="flex items-start gap-2 text-sm text-foreground/80">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4 text-primary mt-0.5 shrink-0"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <!-- CTA -->
              <div class="pt-2 mt-auto border-t border-border">
                <CtaLink
                  href="/contact"
                  variant="card"
                  ariaLabel={`Request a quote for ${service.title}`}
                  className="mt-4"
                >
                  Request a Quote
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </CtaLink>
              </div>

            </div>
          </article>
        </li>
      ))}
    </ul>

    <!-- Footer CTA row -->
    <SectionFooterCta
      copy={content.footerCta.copy}
      href={content.footerCta.href}
      label={content.footerCta.label}
    />

  </div>
</section>
