---
import type { Testimonial } from '../../lib/projects'

interface GuidePrice {
	service: string
	price: string
}

interface Credential {
	title: string
	body: string
	svgPath: string
}

interface Props {
	guidePrices: GuidePrice[]
	credentials: Credential[]
	testimonials: Testimonial[]
}

const { guidePrices, credentials, testimonials } = Astro.props
---

<>
	<section class='py-24 bg-primary text-primary-foreground'>
		<div class='mx-auto max-w-7xl px-6 lg:px-8 text-center'>
			<h2 class='font-serif text-3xl sm:text-4xl font-bold mb-4'>
				Investment Guide
			</h2>
			<p class='text-lg opacity-80 mb-12 max-w-2xl mx-auto'>
				We pride ourselves on transparency. These guide prices help you
				baseline your project requirements.
			</p>

			<div class='grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6'>
				{guidePrices.map((item) => (
					<div class='bg-white/10 border border-white/20 p-6 rounded-2xl'>
						<p class='text-xs font-bold uppercase tracking-widest text-primary-foreground/80 mb-3'>
							{item.service}
						</p>
						<p class='text-2xl font-serif font-bold'>{item.price}</p>
					</div>
				))}
			</div>

			<p class='mt-10 text-sm italic text-primary-foreground/80 max-w-2xl mx-auto'>
				Guide figures only. Your exact quote follows a free site visit and
				design consultation — no obligation.
			</p>
		</div>
	</section>

	<section class='py-24 bg-muted text-muted-foreground'>
		<div class='mx-auto max-w-7xl px-6 lg:px-8 text-center'>
			<h2 class='font-serif text-3xl sm:text-4xl font-bold mb-4'>
				Professional Standards
			</h2>
			<p class='opacity-70 mb-16 max-w-xl mx-auto'>
				We don't just build ponds — we engineer living ecosystems, backed by
				verifiable credentials.
			</p>
			<div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10'>
				{credentials.map((cred) => (
					<div class='flex flex-col items-center'>
						<div class='w-16 h-16 rounded-full border border-white/20 bg-white/5 flex items-center justify-center mb-5'>
							<svg
								xmlns='http://www.w3.org/2000/svg'
								class='w-7 h-7 text-primary'
								fill='none'
								viewBox='0 0 24 24'
								stroke='currentColor'
								stroke-width='1.5'
								aria-hidden='true'
							>
								<path stroke-linecap='round' stroke-linejoin='round' d={cred.svgPath} />
							</svg>
						</div>
						<h4 class='font-bold text-base mb-2'>{cred.title}</h4>
						<p class='text-sm text-muted-foreground/65 leading-relaxed'>{cred.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class='py-24 bg-muted'>
		<div class='mx-auto max-w-7xl px-6 lg:px-8'>
			<div class='text-center mb-16'>
				<h2 class='font-serif text-3xl sm:text-4xl font-bold text-foreground'>
					What Our Clients Say
				</h2>
			</div>
			<div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
				{testimonials.slice(0, 3).map((t) => (
					<div class='bg-card p-8 rounded-3xl border border-foreground/5 shadow-sm flex flex-col'>
						<div class='flex gap-1 text-primary mb-5'>
							{[...Array(5)].map(() => (
								<svg
									xmlns='http://www.w3.org/2000/svg'
									class='w-4 h-4 fill-current'
									viewBox='0 0 20 20'
									aria-hidden='true'
								>
									<path d='M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z' />
								</svg>
							))}
						</div>
						<p class='text-foreground/80 text-sm leading-relaxed italic mb-6 flex-1'>
							"{t.quote}"
						</p>
						<div>
							<p class='font-bold text-sm text-foreground'>{t.name}</p>
							<p class='text-xs text-foreground/60'>{t.location}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>
</>
