---
import type { Project, Service } from '../../lib/projects'

interface Props {
	services: Service[]
	projects: Project[]
}

const { services, projects } = Astro.props
---

<section>
	{services.map((service, i) => {
		const example =
			projects.find((p) => p.serviceType === service.title) ??
			projects[i % projects.length]

		return (
			<div
				id={service.slug}
				class={`py-24 sm:py-32 scroll-mt-20 ${
					i % 2 === 0 ? 'bg-background' : 'bg-muted'
				}`}
			>
				<div class='mx-auto max-w-7xl px-6 lg:px-8'>
					<div
						class={`flex flex-col items-center gap-12 lg:gap-20 lg:flex-row ${
							i % 2 !== 0 ? 'lg:flex-row-reverse' : ''
						}`}
					>
						<div class='flex-1 min-w-0'>
							<span class='badge badge-outline badge-primary font-bold text-xs tracking-wider px-4 py-3 mb-6'>
								{service.title}
							</span>
							<h2 class='font-serif text-3xl sm:text-4xl font-bold text-foreground mt-4 mb-6'>
								{service.title}
							</h2>
							<p class='text-base sm:text-lg text-foreground/80 leading-relaxed mb-8'>
								{service.description}
							</p>

							<ul class='grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 mb-10'>
								{service.features.map((feature) => (
									<li class='flex items-start gap-3'>
										<svg
											xmlns='http://www.w3.org/2000/svg'
											class='w-5 h-5 text-primary shrink-0 mt-0.5'
											fill='none'
											viewBox='0 0 24 24'
											stroke='currentColor'
											stroke-width='2.5'
											aria-hidden='true'
										>
											<path
												stroke-linecap='round'
												stroke-linejoin='round'
												d='M4.5 12.75l6 6 9-13.5'
											/>
										</svg>
										<span class='text-sm font-medium text-foreground/70'>
											{feature}
										</span>
									</li>
								))}
							</ul>

							<div class='flex flex-wrap gap-4 items-center'>
								<a href={`/contact?service=${service.id}`} class='btn btn-primary px-8'>
									Request a Quote
								</a>
								<a href={`/our-work/${example.slug}`} class='flex items-center gap-3 group'>
									<div class='w-12 h-12 rounded-xl overflow-hidden shrink-0 border border-foreground/10'>
										<img
											src={example.thumbnail}
											alt={example.title}
											class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-300'
										/>
									</div>
									<div>
										<p class='text-[10px] uppercase tracking-widest font-bold text-foreground/60'>
											See our work
										</p>
										<p class='text-sm font-semibold text-foreground group-hover:text-primary transition-colors'>
											{example.title}
										</p>
									</div>
								</a>
							</div>
						</div>

						<div class='flex-1 w-full'>
							<div class='aspect-4/3 rounded-3xl overflow-hidden shadow-2xl'>
								<img
									src={service.image}
									alt={`Cornwall Ponds — ${service.title}`}
									class='w-full h-full object-cover hover:scale-105 transition-transform duration-700'
								/>
							</div>
						</div>
					</div>
				</div>
			</div>
		)
	})}
</section>
