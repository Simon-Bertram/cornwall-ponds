---
import type { PhilosophyPillar } from '../../lib/pages/services'

interface Props {
	pillars: PhilosophyPillar[]
}

const { pillars } = Astro.props
---

<section class='py-16 bg-muted'>
	<div class='mx-auto max-w-7xl px-6 lg:px-8'>
		<div class='grid grid-cols-1 md:grid-cols-3 gap-12 text-center'>
			{
				pillars.map((pillar) => (
					<div class='flex flex-col items-center'>
						<div class='bg-primary/10 p-4 rounded-2xl mb-4'>
							<svg
								xmlns='http://www.w3.org/2000/svg'
								class='w-8 h-8 text-primary'
								fill='none'
								viewBox='0 0 24 24'
								stroke='currentColor'
								aria-hidden='true'
							>
								{pillar.svgPaths.map((path) => (
									<path
										stroke-linecap='round'
										stroke-linejoin='round'
										stroke-width='1.5'
										d={path}
									/>
								))}
							</svg>
						</div>
						<h3 class='font-serif text-xl font-bold text-foreground mb-2'>
							{pillar.title}
						</h3>
						<p class='text-foreground/70 text-sm leading-relaxed'>
							{pillar.body}
						</p>
					</div>
				))
			}
		</div>
	</div>
</section>
