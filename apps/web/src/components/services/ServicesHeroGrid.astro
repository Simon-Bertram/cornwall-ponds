---
import { ArrowRight } from 'lucide-react'
import {
	mediaCardActionClass,
	mediaCardBodyClass,
	mediaCardDescriptionClass,
	mediaCardImageClass,
	mediaCardOverlayClass,
	mediaCardShellClass,
	mediaCardTitleClass,
	mediaCardTitleLinkClass,
} from '../../lib/media-card-styles'
import type { Service } from '../../lib/projects'

interface Props {
	services: Service[]
}

const { services } = Astro.props
---

<section class='py-24 sm:py-32 bg-background'>
	<div class='mx-auto max-w-7xl px-6 lg:px-8'>
		<div class='mx-auto max-w-2xl text-center py-16 mb-16'>
			<h1
				class='font-serif text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl mb-6'
			>
				Our Services
			</h1>
			<p class='text-lg text-foreground/80'>
				From bespoke garden ponds and natural swimming pools to koi ponds,
				water features, and year-round maintenance — we design, build, and
				care for water in your landscape across Cornwall.
			</p>
		</div>

		<div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8'>
			{services.map((service) => (
				<div class={mediaCardShellClass}>
					<a
						href={`#${service.slug}`}
						class='block relative aspect-4/3 overflow-hidden focus-visible:ring-2 ring-primary ring-offset-2 rounded-t-xl outline-none'
						aria-label={`View ${service.title} details`}
					>
						<img
							src={service.image}
							alt={`${service.title} — Cornwall Ponds`}
							class={mediaCardImageClass}
							loading='lazy'
						/>
						<div class={mediaCardOverlayClass} />
					</a>

					<div class={mediaCardBodyClass}>
						<a
							href={`#${service.slug}`}
							class={mediaCardTitleLinkClass}
						>
							<h2 class={mediaCardTitleClass}>
								{service.title}
							</h2>
						</a>
						<p class={mediaCardDescriptionClass}>
							{service.shortDescription}
						</p>
						<a
							href={`#${service.slug}`}
							class={mediaCardActionClass}
						>
							Learn more
							<ArrowRight className='h-4 w-4 transition-transform group-hover/btn:translate-x-1' />
						</a>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
