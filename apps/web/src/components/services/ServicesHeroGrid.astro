---
import { ArrowRight } from 'lucide-react'
import type { Service } from '../../lib/projects'

interface Props {
	services: Service[]
}

const { services } = Astro.props
---

<section class='py-24 sm:py-32 bg-background'>
	<div class='mx-auto max-w-7xl px-6 lg:px-8'>
		<div class='mx-auto max-w-2xl text-center py-16 mb-16'>
			<h1
				class='font-serif text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl mb-6'
			>
				Our Services
			</h1>
			<p class='text-lg text-foreground/80'>
				From bespoke garden ponds and natural swimming pools to koi ponds,
				water features, and year-round maintenance — we design, build, and
				care for water in your landscape across Cornwall.
			</p>
		</div>

		<div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8'>
			{services.map((service) => (
				<div class='group flex flex-col h-full bg-card rounded-xl overflow-hidden border border-foreground/10 shadow-sm hover:shadow-xl transition-all duration-300'>
					<a
						href={`#${service.slug}`}
						class='block relative aspect-4/3 overflow-hidden focus-visible:ring-2 ring-primary ring-offset-2 rounded-t-xl outline-none'
						aria-label={`View ${service.title} details`}
					>
						<img
							src={service.image}
							alt={`${service.title} — Cornwall Ponds`}
							class='absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105'
							loading='lazy'
						/>
						<div class='absolute inset-0 bg-linear-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none' />
					</a>

					<div class='p-5 flex flex-col grow'>
						<a
							href={`#${service.slug}`}
							class='group/link mb-2 outline-none focus-visible:ring-2 ring-primary rounded-sm'
						>
							<h2 class='font-serif text-lg sm:text-xl font-bold text-foreground group-hover/link:text-primary transition-colors line-clamp-2'>
								{service.title}
							</h2>
						</a>
						<p class='text-sm text-foreground/80 line-clamp-2 mb-4 grow'>
							{service.shortDescription}
						</p>
						<a
							href={`#${service.slug}`}
							class='mt-auto inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-primary/80 transition-colors w-fit group/btn outline-none focus-visible:ring-2 ring-primary rounded-sm py-1'
						>
							Learn more
							<ArrowRight className='h-4 w-4 transition-transform group-hover/btn:translate-x-1' />
						</a>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
