---
import { navLinks } from "../lib/nav"

const currentPath = Astro.url.pathname
const normalizedPath =
  currentPath === "/" ? "/" : currentPath.replace(/\/$/, "")
---

<nav aria-label="Primary" class="hidden xl:block">
  <ul class="flex items-center gap-2">
    {
      navLinks.map((link) => {
        const isActive =
          link.href === "/"
            ? normalizedPath === "/"
            : normalizedPath.startsWith(link.href)

        return (
          <li>
            <a
              href={link.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "inline-flex rounded-lg border px-3 py-2 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background",
                isActive
                  ? "border-primary/45 bg-primary/20 text-foreground font-bold"
                  : "border-transparent text-foreground hover:border-border hover:bg-muted",
              ]}
            >
              {link.label}
            </a>
          </li>
        )
      })
    }
  </ul>
</nav>
