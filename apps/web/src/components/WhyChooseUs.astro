---
import SectionHeader from './SectionHeader.astro'
import type {
	TrustPillar,
	TrustPillarIcon,
	TrustStat,
} from '../lib/pages/expertise'

interface Props {
	eyebrow: string
	title: string
	description: string
	pillars: TrustPillar[]
	stats: TrustStat[]
	headingId?: string
}

const {
	eyebrow,
	title,
	description,
	pillars,
	stats,
	headingId = 'why-choose-us-heading',
} = Astro.props as Props

const iconPaths: Record<TrustPillarIcon, string[]> = {
	trophy: ['M8 21h8m-4-4v4m-7-9V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v7M3 10a6 6 0 0 0 6 6h6a6 6 0 0 0 6-6H3Z'],
	leaf: [
		'M12 2C6.5 2 2 6.5 2 12c0 2.4.86 4.6 2.29 6.33L12 22l7.71-3.67A10 10 0 0 0 22 12C22 6.5 17.5 2 12 2Z',
		'M12 2v20',
	],
	shield: ['M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z'],
	heart: ['M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78Z'],
}
---

<section
	aria-labelledby={headingId}
	class='bg-muted py-24 sm:py-32'
>
	<div class='mx-auto max-w-7xl px-6 lg:px-8'>
		<SectionHeader
			eyebrow={eyebrow}
			title={title}
			description={description}
			headingId={headingId}
			className='mb-16'
		/>

		<div class='grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4'>
			{pillars.map((pillar) => (
				<div class='trust-card group flex flex-col items-center rounded-2xl bg-card p-8 text-center shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md'>
					<div
						class='pond-shape mb-6 flex h-16 w-16 items-center justify-center bg-secondary text-secondary-foreground transition-transform duration-300 group-hover:scale-105'
						aria-hidden='true'
					>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='h-7 w-7'
							fill='none'
							viewBox='0 0 24 24'
							stroke='currentColor'
							stroke-width='1.75'
							aria-hidden='true'
						>
							{iconPaths[pillar.icon].map((path) => (
								<path
									stroke-linecap='round'
									stroke-linejoin='round'
									d={path}
								/>
							))}
						</svg>
					</div>
					<h3 class='mb-2 font-serif text-lg font-bold text-primary'>
						{pillar.title}
					</h3>
					<p class='text-sm leading-relaxed text-foreground/70'>
						{pillar.body}
					</p>
				</div>
			))}
		</div>

		<div class='mt-16 grid grid-cols-2 gap-8 border-t border-border pt-12 sm:grid-cols-4'>
			{stats.map((stat) => (
				<div class='text-center'>
					<p class='font-serif text-4xl font-bold text-primary'>{stat.value}</p>
					<p class='mt-1 text-sm text-foreground/60'>{stat.label}</p>
				</div>
			))}
		</div>
	</div>
</section>
