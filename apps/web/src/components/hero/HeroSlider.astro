---
import { heroContent } from "./hero-content";
import HeroSliderControls from "./HeroSliderControls.astro";
import HeroTrustBadge from "./HeroTrustBadge.astro";

const { slides, ctas, regionLabel } = heroContent;
---

<section
  class="hero min-h-[600px] h-screen max-h-[1100px] relative overflow-hidden bg-black"
  id="hero-slider"
  role="region"
  aria-roledescription="carousel"
  aria-label={regionLabel}
>
  {
    slides.map((slide, index) => (
      <div
        class={`slide absolute inset-0 transition-opacity duration-1000 flex items-center justify-center ${index === 0 ? "opacity-100 z-10" : "opacity-0 z-0"}`}
        data-index={index}
        aria-hidden={index !== 0 ? "true" : "false"}
        {...(index !== 0 ? { inert: true } : {})}
        role="group"
        aria-roledescription="slide"
        aria-label={`Slide ${index + 1} of ${slides.length}: ${slide.title}`}
      >
        {/* Background Image Loading Architecture (LCP vs Lazy) */}
        <img
          src={slide.image}
          alt={slide.title}
          fetchpriority={slide.priority ? "high" : "auto"}
          loading={slide.priority ? "eager" : "lazy"}
          decoding={slide.priority ? "sync" : "async"}
          class="absolute inset-0 w-full h-full object-cover z-0"
        />
        {/* Foreground Content */}
        <div class="hero-content text-center relative z-10 w-full max-w-5xl mx-auto px-6 py-12 sm:px-16 sm:py-20 mt-16 sm:mt-24 bg-[radial-gradient(ellipse_78%_62%_at_center,rgba(0,0,0,0.72)_0%,rgba(0,0,0,0.52)_40%,rgba(0,0,0,0.22)_55%,transparent_68%,transparent_100%)]">
          <div class="max-w-4xl mx-auto flex flex-col items-center gap-6 sm:gap-8">
            <HeroTrustBadge />

            {/* Main Luxury Typography & SEO Node injection */}
            {index === 0 ? (
              <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-sans font-bold tracking-tight text-white leading-tight text-balance">
                {slide.title} <br class="hidden sm:block" />
                <span class="text-white italic font-serif font-light text-3xl sm:text-4xl md:text-5xl lg:text-6xl mt-2 block">
                  {slide.subtitle}
                </span>
              </h1>
            ) : (
              <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-sans font-bold tracking-tight text-white leading-tight text-balance">
                {slide.title} <br class="hidden sm:block" />
                <span class="text-white italic font-serif font-light text-3xl sm:text-4xl md:text-5xl lg:text-6xl mt-2 block">
                  {slide.subtitle}
                </span>
              </h2>
            )}

            <p class="a11y-hero-supporting text-white rounded-xl px-2 py-2 text-base sm:text-lg font-semibold max-w-2xl mx-auto leading-relaxed mt-2 text-balance lg:min-h-12 backdrop-blur-[1px]">
              {slide.description}
            </p>

            {/* Luxury CTAs */}
            <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 mt-6 w-full sm:w-auto overflow-hidden">
              {ctas.map((cta) => (
                <a
                  href={cta.href}
                  class={`btn btn-lg w-full sm:w-auto font-bold text-base px-8 pond-shape rounded-xl antialiased ${cta.tone === "primary" ? "btn-primary shadow-lg shadow-primary/30" : "btn-outline hover:bg-white/20 bg-white/10 backdrop-blur-sm text-white border-white/30 transition-all"}`}
                >
                  {cta.label}
                  {cta.tone === "primary" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4 ml-2"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  )}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))
  }

  <HeroSliderControls slideCount={slides.length} />
</section>

<script>
  import { initHeroSlider } from "./hero-slider-init";

  function attachHeroSlider() {
    const sliderContainer = document.getElementById("hero-slider");
    if (!sliderContainer) return;

    // Delay initialization slightly so we don't compete with first paint.
    window.requestAnimationFrame(() => {
      initHeroSlider(sliderContainer, { intervalMs: 7000 });
    });
  }

  document.addEventListener("astro:page-load", attachHeroSlider);

  if (
    document.readyState === "complete" ||
    document.readyState === "interactive"
  ) {
    attachHeroSlider();
  } else {
    document.addEventListener("DOMContentLoaded", attachHeroSlider);
  }
</script>
