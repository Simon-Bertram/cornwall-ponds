---
interface Props {
  slideCount: number
}

const { slideCount } = Astro.props
---

<div class="absolute bottom-8 left-0 right-0 z-30 flex flex-col items-center gap-3">
  <div
    class="flex justify-center gap-3"
    aria-label="Hero slides"
  >
    {
      Array.from({ length: slideCount }, (_, index) => (
        <button
          class={`indicator-btn h-2 w-8 rounded-full transition-all duration-500 cursor-pointer focus:outline-none focus-visible:ring-2 ring-white ring-offset-2 ring-offset-black/50 ${index === 0 ? "bg-white" : "bg-white/55 hover:bg-white/75"}`}
          data-index={index}
          type="button"
          aria-label={`Go to slide ${index + 1}`}
          aria-pressed={index === 0 ? "true" : "false"}
          aria-current={index === 0 ? "true" : undefined}
        />
      ))
    }
  </div>
  <button
    type="button"
    data-hero-slider-pause
    class="mt-1 inline-flex items-center gap-2 rounded-full bg-black/45 px-4 py-1.5 text-xs font-medium text-white border border-white/35 backdrop-blur-sm hover:bg-black/55 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-black/60"
    aria-pressed="false"
  >
    Pause slideshow
  </button>
</div>
