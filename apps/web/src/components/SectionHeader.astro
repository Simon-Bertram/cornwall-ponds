---
interface Props {
	title: string
	description: string
	eyebrow?: string
	headingId?: string
	headingTag?: 'h1' | 'h2' | 'h3'
	className?: string
	descriptionClassName?: string
}

const {
	title,
	description,
	eyebrow,
	headingId,
	headingTag = 'h2',
	className = '',
	descriptionClassName = 'text-foreground/70',
} = Astro.props

const HeadingTag = headingTag
---

<div class={`mx-auto max-w-2xl text-center ${className}`.trim()}>
	{
		eyebrow && (
			<p class='mb-3 text-sm font-semibold uppercase tracking-widest text-primary'>
				{eyebrow}
			</p>
		)
	}
	<HeadingTag
		id={headingId}
		class='font-serif text-3xl font-bold tracking-tight text-foreground sm:text-4xl'
	>
		{title}
	</HeadingTag>
	<p class={`mt-4 text-lg leading-relaxed ${descriptionClassName}`.trim()}>
		{description}
	</p>
</div>
