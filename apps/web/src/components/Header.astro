---
import { Menu, X } from "@lucide/astro";
import AuthButton from "./AuthButton.astro";
// import ThemeToggle from "./ThemeToggle.astro";
import HeaderPrimaryNavCustom from "./HeaderPrimaryNavCustom.astro";
import HeaderMobileMenuPanelCustom from "./HeaderMobileMenuPanelCustom.astro";
import { lucideIconToSvg } from "../lib/lucide-icon-svg";

const menuSvg = lucideIconToSvg(Menu, "h-5 w-5");
const closeSvg = lucideIconToSvg(X, "h-5 w-5");
---

<header class="border-b border-border bg-background">
  <div
    class="mx-auto flex w-full max-w-7xl items-center justify-between gap-3 px-4 py-2 md:px-6"
  >
    <a
      href="/"
      class="font-display text-lg font-semibold text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
    >
      Cornwall Ponds
    </a>

    <HeaderPrimaryNavCustom />

    <div class="flex items-center gap-3">
      <!-- <ThemeToggle /> -->
      <AuthButton />
      <button
        id="mobile-menu-button"
        type="button"
        class="btn btn-ghost btn-square xl:hidden focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
        aria-label="Toggle main menu"
        aria-controls="mobile-menu-panel"
        aria-expanded="false"
      >
        <span id="mobile-menu-open-icon" aria-hidden="true">
          <Fragment set:html={menuSvg} />
        </span>
        <span id="mobile-menu-close-icon" class="hidden" aria-hidden="true">
          <Fragment set:html={closeSvg} />
        </span>
      </button>
    </div>
  </div>

  <HeaderMobileMenuPanelCustom />
</header>

<script is:inline>
  (function () {
    const menuButton = document.getElementById("mobile-menu-button");
    const menuPanel = document.getElementById("mobile-menu-panel");
    const openIcon = document.getElementById("mobile-menu-open-icon");
    const closeIcon = document.getElementById("mobile-menu-close-icon");
    const menuLinks = menuPanel?.querySelectorAll("[data-mobile-menu-link]");
    const desktopBreakpoint = window.matchMedia("(min-width: 1280px)");

    if (!menuButton || !menuPanel || !openIcon || !closeIcon) {
      return;
    }

    const setMenuOpen = (isOpen) => {
      menuButton.setAttribute("aria-expanded", String(isOpen));
      menuPanel.classList.toggle("hidden", !isOpen);
      openIcon.classList.toggle("hidden", isOpen);
      closeIcon.classList.toggle("hidden", !isOpen);
    };

    const closeMenu = ({ restoreFocus } = { restoreFocus: true }) => {
      setMenuOpen(false);

      if (restoreFocus) {
        menuButton.focus();
      }
    };

    menuButton.addEventListener("click", () => {
      const isOpen = menuButton.getAttribute("aria-expanded") === "true";
      const nextOpenState = !isOpen;
      setMenuOpen(nextOpenState);

      if (nextOpenState) {
        menuLinks?.[0]?.focus();
      }
    });

    menuLinks?.forEach((link) => {
      link.addEventListener("click", () => closeMenu({ restoreFocus: false }));
    });

    document.addEventListener("keydown", (event) => {
      const isOpen = menuButton.getAttribute("aria-expanded") === "true";
      if (event.key === "Escape" && isOpen) {
        closeMenu({ restoreFocus: true });
      }
    });

    desktopBreakpoint.addEventListener("change", (event) => {
      if (event.matches) {
        closeMenu({ restoreFocus: false });
      }
    });
  })();
</script>
