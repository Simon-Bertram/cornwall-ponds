---
import SiteNavLinks from './SiteNavLinks.astro'
import {
	HEADER_NAV_LINK_ACTIVE,
	HEADER_NAV_LINK_INACTIVE,
} from '@/lib/header-nav-styles'
---

<SiteNavLinks
	navLabel='Primary'
	navClass='hidden xl:block'
	listClass='flex items-center gap-2'
	linkBaseClass='inline-flex rounded-lg border px-3 py-2 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background'
	activeClass={HEADER_NAV_LINK_ACTIVE}
	inactiveClass={HEADER_NAV_LINK_INACTIVE}
/>
