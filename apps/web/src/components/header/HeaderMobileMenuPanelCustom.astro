---
import SiteNavLinks from './SiteNavLinks.astro'
---

<div
	id='mobile-menu-panel'
	class='hidden border-t border-border bg-background xl:hidden'
>
	<SiteNavLinks
		navLabel='Primary mobile'
		listClass='flex flex-col gap-1 px-2 py-2'
		linkBaseClass='block rounded-lg border px-3 py-3 text-base font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background'
		activeClass='border-primary text-primary font-bold'
		inactiveClass='border-transparent text-foreground hover:border-border hover:bg-muted'
		addMobileHook
	/>
</div>
