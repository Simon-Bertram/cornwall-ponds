---
import { Phone, Mail, MapPin, CircleCheckBig } from "lucide-react";
import { siteSettings } from "../../lib/site-settings";
import ContactDetailRow from "./ContactDetailRow.astro";
---

<div
  class="w-full flex flex-col gap-10 rounded-3xl border border-primary/10 bg-primary/5 p-8 sm:p-10"
>
  <div>
    <h3 class="font-serif text-2xl font-bold text-foreground mb-2">
      Contact Details
    </h3>
    <p class="text-foreground/70">
      Prefer to speak directly? Reach out to our team using the details below.
    </p>
  </div>

  <div class="flex flex-col gap-8">
    <ContactDetailRow title="Phone">
      <Phone slot="icon" size={24} />
      <a
        href={siteSettings.phone.href}
        class="text-lg text-foreground/80 hover:text-primary transition-colors block mt-1"
        >{siteSettings.phone.display}</a
      >
      <p class="text-sm text-foreground/60 mt-1">{siteSettings.openingHours}</p>
    </ContactDetailRow>

    <ContactDetailRow title="Email">
      <Mail slot="icon" size={24} />
      <a
        href={`mailto:${siteSettings.email}`}
        class="text-lg text-foreground/80 hover:text-primary transition-colors block mt-1"
        >{siteSettings.email}</a
      >
    </ContactDetailRow>

    <ContactDetailRow title="Office">
      <MapPin slot="icon" size={24} />
      <p class="text-lg text-foreground/80 mt-1">
        {
          siteSettings.address.lines.map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))
        }
      </p>
    </ContactDetailRow>
  </div>

  <div class="mt-auto pt-8 border-t border-foreground/10">
    <p
      class="text-sm font-bold text-foreground/80 flex items-center gap-2"
    >
      <CircleCheckBig size={20} />
      Fully Insured &amp; Guaranteed Work
    </p>
  </div>
</div>
