---
interface Props {
  title: string
}

const { title } = Astro.props
---

<div class="flex items-start gap-4">
  <div
    class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary shrink-0"
  >
    <slot name="icon" />
  </div>
  <div>
    <h4 class="font-bold text-foreground">{title}</h4>
    <slot />
  </div>
</div>
