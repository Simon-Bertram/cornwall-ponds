---
import ContactFormSection from "./ContactFormSection.astro";
---

<div
  class="lg:col-span-3 bg-card rounded-3xl p-8 sm:p-10 border border-foreground/10 shadow-xl shadow-foreground/5"
>
  <form class="flex flex-col gap-8" action="/api/contact" method="POST">
    <ContactFormSection title="1. Your Details">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="form-control gap-2">
          <label class="label pt-0"
            ><span class="label-text font-bold text-foreground/80"
              >First Name *</span
            ></label
          >
          <input
            type="text"
            name="firstName"
            required
            placeholder="John"
            class="input input-bordered w-full bg-muted/50 focus:bg-card focus:border-primary transition-colors"
          />
        </div>
        <div class="form-control gap-2">
          <label class="label pt-0"
            ><span class="label-text font-bold text-foreground/80"
              >Last Name *</span
            ></label
          >
          <input
            type="text"
            name="lastName"
            required
            placeholder="Smith"
            class="input input-bordered w-full bg-muted/50 focus:bg-card focus:border-primary transition-colors"
          />
        </div>
        <div class="form-control gap-2">
          <label class="label pt-0"
            ><span class="label-text font-bold text-foreground/80"
              >Email Address *</span
            ></label
          >
          <input
            type="email"
            name="email"
            required
            placeholder="john@example.com"
            class="input input-bordered w-full bg-muted/50 focus:bg-card focus:border-primary transition-colors"
          />
        </div>
        <div class="form-control gap-2">
          <label class="label pt-0"
            ><span class="label-text font-bold text-foreground/80"
              >Phone Number *</span
            ></label
          >
          <input
            type="tel"
            name="phone"
            required
            placeholder="07700 900000"
            class="input input-bordered w-full bg-muted/50 focus:bg-card focus:border-primary transition-colors"
          />
        </div>
      </div>
    </ContactFormSection>

    <ContactFormSection title="2. Project Details">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="form-control gap-2">
          <label class="label pt-0"
            ><span class="label-text font-bold text-foreground/80"
              >Service Required *</span
            ></label
          >
          <select
            name="service"
            required
            class="select select-bordered w-full bg-muted/50 focus:bg-card focus:border-primary transition-colors font-medium"
          >
            <option disabled selected>Select a Service</option>
            <option value="Garden Pond">Garden Pond</option>
            <option value="Natural Swimming Pond">Natural Swimming Pond</option>
            <option value="Koi Pond">Koi Pond</option>
            <option value="Water Feature">Water Feature</option>
            <option value="Maintenance">Maintenance &amp; Restoration</option>
          </select>
        </div>
        <div class="form-control gap-2">
          <label class="label pt-0"
            ><span class="label-text font-bold text-foreground/80"
              >Estimated Budget *</span
            ></label
          >
          <select
            name="budget"
            required
            class="select select-bordered w-full bg-muted/50 focus:bg-card focus:border-primary transition-colors font-medium"
          >
            <option disabled selected>Guide Pricing</option>
            <option value="Under £5k">Under £5,000</option>
            <option value="£5k - £15k">£5,000 - £15,000</option>
            <option value="£15k - £30k">£15,000 - £30,000</option>
            <option value="£30k+">£30,000+</option>
          </select>
        </div>
        <div class="form-control gap-2 sm:col-span-2">
          <label class="label pt-0"
            ><span class="label-text font-bold text-foreground/80"
              >Project Postcode *</span
            ></label
          >
          <input
            type="text"
            name="postcode"
            required
            placeholder="TR1 1AA"
            class="input input-bordered w-full sm:w-1/2 bg-muted/50 focus:bg-card focus:border-primary transition-colors"
          />
        </div>
        <div class="form-control gap-2 sm:col-span-2">
          <label class="label pt-0"
            ><span class="label-text font-bold text-foreground/80"
              >Tell us about your vision *</span
            ></label
          >
          <textarea
            name="message"
            required
            rows="4"
            placeholder="Briefly describe your garden space, ideas, and any specific requirements you have..."
            class="textarea textarea-bordered w-full text-base bg-muted/50 focus:bg-card focus:border-primary transition-colors resize-y"
          ></textarea>
        </div>
      </div>
    </ContactFormSection>

    <div class="pt-6 border-t border-foreground/10">
      <button
        type="submit"
        class="btn btn-primary btn-lg w-full font-bold shadow-lg shadow-primary/20 hover:scale-[1.01] transition-transform"
      >
        Submit Consultation Request
      </button>
      <p
        class="text-xs text-center text-foreground/60 mt-4 leading-relaxed max-w-lg mx-auto"
      >
        By submitting this form, you agree to our privacy policy. We will only
        use your information to contact you regarding your enquiry and never
        share it with third parties.
      </p>
    </div>
  </form>
</div>
