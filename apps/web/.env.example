# Local dev: copy to .env.development (or rely on astro.config default)
PUBLIC_SERVER_URL=http://localhost:3000

# Cloudflare Turnstile (Dashboard → Turnstile → Add widget)
# Site key is public; secret key goes in apps/server/.env
# PUBLIC_TURNSTILE_SITE_KEY=

# Production deploy: copy to .env.production (loaded by Alchemy on deploy)
# PUBLIC_SERVER_URL=https://your-server-worker.workers.dev
# PUBLIC_TURNSTILE_SITE_KEY=
