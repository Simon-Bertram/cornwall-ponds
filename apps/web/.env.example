# Local dev: copy to .env.development (or rely on astro.config defaults)
PUBLIC_SERVER_URL=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:4321

# Must match WEB_URL in apps/server/.env.development (Better Auth trustedOrigins)
# Cloudflare Turnstile (Dashboard → Turnstile → Add widget)
# Site key is public; secret key goes in apps/server/.env
# PUBLIC_TURNSTILE_SITE_KEY=

# Optional: SSR redirect for /dashboard and /account when session cookies are visible on SSR
# (same-site / shared cookie domain). Bound on the web Worker via Alchemy.
# ENABLE_SSR_PROTECTED_REDIRECT=true

# Production deploy: copy to .env.production (loaded by Alchemy on deploy)
# PUBLIC_SERVER_URL=https://your-server-worker.workers.dev
# PUBLIC_WEB_URL=https://your-web-worker.workers.dev
# PUBLIC_TURNSTILE_SITE_KEY=
