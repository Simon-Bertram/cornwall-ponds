# Copy to apps/server/.env and fill secrets (never commit .env).
#
# Google OAuth (Cloud Console → Credentials → OAuth client ID → Web application):
#   Authorized redirect URI (local):  http://localhost:3000/api/auth/callback/google
#   Authorized redirect URI (prod):   {BETTER_AUTH_URL from .env.production}/api/auth/callback/google
#   Authorized JavaScript origin (local): http://localhost:4321
#   Authorized JavaScript origin (prod):  {WEB_URL from .env.production}
#
# Resend: API key + verified sender (or onboarding@resend.dev for dev-only testing).

BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Auth <onboarding@resend.dev>
CONTACT_TO_EMAIL=you@example.com

# Cloudflare Turnstile (secret key — never expose in the web app)
# TURNSTILE_SECRET_KEY=
# Production (ENVIRONMENT=production): missing secret rejects sign-in and contact unless
# TURNSTILE_FAIL_OPEN=true (not recommended for public traffic).
#
# /api-reference: enabled when ENVIRONMENT is development or OPENAPI_REFERENCE_ENABLED=true
# OPENAPI_REFERENCE_ENABLED=true
#
# Alchemy sets ENVIRONMENT (development vs production). For wrangler-only runs, set manually.

# Cloudflare Access (production only — copy to .env.production on deploy)
# POLICY_AUD=
# CF_ACCESS_DOMAIN=https://your-team.cloudflareaccess.com
# CF_ACCESS_ENABLED=true

# Local URLs → copy to .env.development (loaded by Alchemy dev)
# CF_ACCESS_ENABLED=false
# BETTER_AUTH_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:4321
# WEB_URL=http://localhost:4321

# Production URLs → copy to .env.production (loaded by Alchemy deploy)
# No trailing slashes on origins (Better Auth trustedOrigins exact match).
# BETTER_AUTH_URL=https://your-server-worker.workers.dev
# CORS_ORIGIN=https://your-web-worker.workers.dev
# WEB_URL=https://your-web-worker.workers.dev
# CF_ACCESS_ENABLED=false

# --- Manual verification (pnpm dev from repo root) ---
# curl -sS http://localhost:3000/api/auth/ok
# curl -sS http://localhost:3000/health
# Logged in: copy session cookie from browser, then:
# curl -sS -X POST http://localhost:3000/rpc/me -H 'Content-Type: application/json' -H 'Cookie: <session-cookie>' -d '{"json":{},"meta":[]}'
# Logged out: open http://localhost:4321/dashboard → client redirect to /login (RequireAuth)
# Magic link: submit login on :4321 → email link hits :3000 verify → redirect to PUBLIC_WEB_URL/dashboard
# Google: OAuth callback on :3000 → redirect to PUBLIC_WEB_URL/dashboard (must match WEB_URL)
# PUBLIC_WEB_URL (apps/web) must equal WEB_URL here for auth callback redirects
# Optional later (custom parent domain only): COOKIE_DOMAIN=.example.com + crossSubDomainCookies in packages/auth
# Turnstile: set PUBLIC_TURNSTILE_SITE_KEY (web) + TURNSTILE_SECRET_KEY (server); omit both to skip in dev
#
# First admin: set ADMIN_EMAIL in apps/server/.env — promoted to role=admin on login
# ADMIN_EMAIL=you@example.com
