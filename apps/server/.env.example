# Secrets (keep in .env — not committed)
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Local URLs → .env.development
# BETTER_AUTH_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:4321
# WEB_URL=http://localhost:4321

# Production URLs → .env.production (loaded by Alchemy on deploy)
# BETTER_AUTH_URL=https://your-server-worker.workers.dev
# CORS_ORIGIN=https://your-web-worker.workers.dev
# WEB_URL=https://your-web-worker.workers.dev
