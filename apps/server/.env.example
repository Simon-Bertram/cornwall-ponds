# Copy to apps/server/.env and fill secrets (never commit .env).
#
# Google OAuth (Cloud Console → Credentials → OAuth client ID → Web application):
#   Authorized redirect URI (local):  http://localhost:3000/api/auth/callback/google
#   Authorized redirect URI (prod):   {BETTER_AUTH_URL from .env.production}/api/auth/callback/google
#   Authorized JavaScript origin (local): http://localhost:4321
#   Authorized JavaScript origin (prod):  {WEB_URL from .env.production}
#
# Resend: API key + verified sender (or onboarding@resend.dev for dev-only testing).

BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Auth <onboarding@resend.dev>

# Cloudflare Access (production only — copy to .env.production on deploy)
# POLICY_AUD=
# CF_ACCESS_DOMAIN=https://your-team.cloudflareaccess.com
# CF_ACCESS_ENABLED=true

# Local URLs → copy to .env.development (loaded by Alchemy dev)
# CF_ACCESS_ENABLED=false
# BETTER_AUTH_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:4321
# WEB_URL=http://localhost:4321

# Production URLs → copy to .env.production (loaded by Alchemy deploy)
# BETTER_AUTH_URL=https://your-server-worker.workers.dev
# CORS_ORIGIN=https://your-web-worker.workers.dev
# WEB_URL=https://your-web-worker.workers.dev
